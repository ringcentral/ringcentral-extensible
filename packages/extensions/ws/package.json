{
  "name": "@rc-ex/ws",
  "version": "1.5.0",
  "description": "WebSocket extension for ringcentral-extensible project",
  "author": "Tyler Liu <tyler.liu@ringcentral.com>",
  "homepage": "https://github.com/ringcentral/ringcentral-extensible/tree/master/packages/extensions/ws",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./lib/*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "require": "./dist/*.cjs"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "require": "./dist/*.cjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ringcentral/ringcentral-extensible.git"
  },
  "bugs": {
    "url": "https://github.com/ringcentral/ringcentral-extensible/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@types/ws": "^8.18.1",
    "http-status-codes": "^2.3.0",
    "hyperid": "^3.3.0",
    "isomorphic-ws": "^5.0.0",
    "wait-for-async": "^0.8.0",
    "ws": "^8.20.0"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts && tsc -p tsconfig.esm.json --declaration --emitDeclarationOnly --outDir dist"
  },
  "type": "module"
}
