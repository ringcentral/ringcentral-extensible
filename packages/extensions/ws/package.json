{
  "name": "@rc-ex/ws",
  "version": "1.5.1",
  "description": "WebSocket extension for ringcentral-extensible project",
  "author": "Tyler Liu <tyler.liu@ringcentral.com>",
  "homepage": "https://github.com/ringcentral/ringcentral-extensible/tree/master/packages/extensions/ws",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./*": {
      "import": {
        "types": "./dist/*.d.mts",
        "default": "./dist/*.mjs"
      },
      "require": {
        "types": "./dist/*.d.cts",
        "default": "./dist/*.cjs"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ringcentral/ringcentral-extensible.git"
  },
  "bugs": {
    "url": "https://github.com/ringcentral/ringcentral-extensible/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@types/ws": "^8.18.1",
    "http-status-codes": "^2.3.0",
    "hyperid": "^3.3.0",
    "isomorphic-ws": "^5.0.0",
    "wait-for-async": "^0.8.0",
    "ws": "^8.20.0"
  },
  "peerDependencies": {
    "@rc-ex/core": "workspace:^"
  },
  "devDependencies": {
    "@rc-ex/core": "workspace:^"
  },
  "scripts": {
    "build": "tsdown"
  },
  "type": "module"
}
