{
  "name": "@rc-ex/rate-limit",
  "version": "1.4.0",
  "description": "Rate limit extension for ringcentral-extensible project",
  "author": "Tyler Liu <tyler.liu@ringcentral.com>",
  "homepage": "https://github.com/ringcentral/ringcentral-extensible/tree/master/packages/extensions/rate-limit",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ringcentral/ringcentral-extensible.git"
  },
  "bugs": {
    "url": "https://github.com/ringcentral/ringcentral-extensible/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@rc-ex/core": "workspace:^"
  },
  "dependencies": {
    "@rc-ex/retry": "workspace:^"
  },
  "devDependencies": {
    "@rc-ex/core": "workspace:^"
  },
  "scripts": {
    "build": "tsdown"
  },
  "type": "module"
}
