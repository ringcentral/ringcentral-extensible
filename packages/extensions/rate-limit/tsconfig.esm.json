{
  "compilerOptions": {
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@rc-ex/retry": [
        "../retry/src/index.ts"
      ],
      "@rc-ex/retry/*": [
        "../retry/src/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts"
  ]
}
