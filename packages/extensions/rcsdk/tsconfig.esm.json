{
  "compilerOptions": {
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@rc-ex/core": [
        "../../core/src/index.ts"
      ],
      "@rc-ex/core/*": [
        "../../core/src/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts"
  ]
}
