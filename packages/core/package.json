{
  "name": "@rc-ex/core",
  "version": "1.8.1",
  "description": "Core for ringcentral-extensible project",
  "author": "Tyler Liu <tyler.liu@ringcentral.com>",
  "homepage": "https://github.com/ringcentral/ringcentral-extensible/tree/master/packages/core",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./*": {
      "import": {
        "types": "./dist/*.d.mts",
        "default": "./dist/*.mjs"
      },
      "require": {
        "types": "./dist/*.d.cts",
        "default": "./dist/*.cjs"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ringcentral/ringcentral-extensible.git"
  },
  "bugs": {
    "url": "https://github.com/ringcentral/ringcentral-extensible/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "qs": "^6.15.3"
  },
  "devDependencies": {
    "@types/qs": "^6.15.1",
    "dotenv-override-true": "^6.2.2",
    "ringcentral-code-generator": "^0.8.0"
  },
  "scripts": {
    "build": "tsdown"
  },
  "type": "module"
}
