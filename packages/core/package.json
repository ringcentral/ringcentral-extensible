{
  "name": "@rc-ex/core",
  "version": "1.7.4",
  "description": "Core for ringcentral-extensible project",
  "author": "Tyler Liu <tyler.liu@ringcentral.com>",
  "homepage": "https://github.com/ringcentral/ringcentral-extensible/tree/master/packages/core",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "types": "./dist/esm/index.d.ts",
  "main": "./dist/esm/index.js",
  "module": "./dist/esm/index.js",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js"
    },
    "./lib/*": {
      "types": "./dist/esm/*.d.ts",
      "import": "./dist/esm/*.js"
    },
    "./*": {
      "types": "./dist/esm/*.d.ts",
      "import": "./dist/esm/*.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ringcentral/ringcentral-extensible.git"
  },
  "bugs": {
    "url": "https://github.com/ringcentral/ringcentral-extensible/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@types/qs": "^6.14.0",
    "axios": "^1.13.2",
    "qs": "^6.14.1"
  },
  "devDependencies": {
    "dotenv-override-true": "^6.2.2",
    "ringcentral-code-generator": "^0.7.6"
  },
  "scripts": {
    "build": "tsc -p tsconfig.esm.json"
  },
  "type": "module"
}
